<?xml version="1.0" encoding="utf-8"?>
<!--
    Animator-заглушка для анимации count-up на TextView.
    ValueAnimator нельзя применить к произвольному свойству через XML напрямую.
    Применять программно в onViewCreated:

    fun animateCounter(tv: TextView, endValue: Float, format: String = "%.1f") {
        ValueAnimator.ofFloat(0f, endValue).apply {
            duration = 800
            interpolator = DecelerateInterpolator()
            addUpdateListener {
                tv.text = format.format(it.animatedValue as Float)
            }
            start()
        }
    }

    // Вызов:
    animateCounter(tvAvgConsumption, 8.4f, "%.1f")
    animateCounter(tvBestConsumption, 7.2f, "%.1f")
    animateCounter(tvTotalSpent, 45230f, "%.0f ₽")
    animateCounter(tvTotalLiters, 780.5f, "%.1f л")
-->
<objectAnimator
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:propertyName="alpha"
    android:valueFrom="0"
    android:valueTo="1"
    android:duration="800"
    android:interpolator="@android:interpolator/decelerate_quad" />