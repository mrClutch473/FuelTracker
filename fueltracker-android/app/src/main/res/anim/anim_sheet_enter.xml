<?xml version="1.0" encoding="utf-8"?>
<!--
    Bottom Sheet entrance: slides in from bottom, 350ms, decelerate cubic feel.
    Apply in BottomSheetDialogFragment.onCreateDialog after super():
        bottomSheet.startAnimation(AnimationUtils.loadAnimation(context, R.anim.anim_sheet_enter))
    Либо стандартный BottomSheetBehavior уже анимирует появление — этот файл
    можно подключить вручную к custom dialog transition.
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="350"
    android:fromYDelta="100%p"
    android:interpolator="@android:anim/decelerate_interpolator"
    android:toYDelta="0%p" />