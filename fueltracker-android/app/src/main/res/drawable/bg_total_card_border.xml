<?xml version="1.0" encoding="utf-8"?>
<!--
    Amber-bordered card background for the total summary block.
    Альтернатива MaterialCardView strokeColor — можно использовать как android:background
    на обычном View/FrameLayout если не нужен ripple.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#1A1F2E" />
    <stroke
        android:width="1dp"
        android:color="#F5A623" />
    <corners android:radius="12dp" />

</shape>