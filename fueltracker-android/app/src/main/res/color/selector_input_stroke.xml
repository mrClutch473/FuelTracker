<?xml version="1.0" encoding="utf-8"?>
<!--
    ColorStateList для app:boxStrokeColor TextInputLayout.
    Focused  → Amber #F5A623  (Border Input Active)
    Default  → #2A3040        (Border Input)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true"  android:color="#F5A623" />
    <item android:state_hovered="true"  android:color="#F5A623" />
    <item                               android:color="#2A3040" />

</selector>