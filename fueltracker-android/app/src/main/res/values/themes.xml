<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ОСНОВНАЯ ТЕМА ПРИЛОЖЕНИЯ                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.FuelTracker" parent="Theme.Material3.Dark.NoActionBar">

        <item name="colorSecondaryContainer">#1AF5A623</item>

        <!-- Отключить стандартный ActionBar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Цвета Material3 -->
        <item name="colorPrimary">#F5A623</item>
        <item name="colorOnPrimary">#0A0D14</item>
        <item name="colorPrimaryContainer">#33F5A623</item>
        <item name="colorOnPrimaryContainer">#F5A623</item>

        <item name="colorSecondary">#4FC3F7</item>
        <item name="colorOnSecondary">#0A0D14</item>

        <item name="colorTertiary">#00E676</item>
        <item name="colorOnTertiary">#0A0D14</item>

        <item name="colorSurface">#12161F</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorSurfaceVariant">#1A1F2E</item>
        <item name="colorOnSurfaceVariant">#8892A4</item>

        <item name="colorOnBackground">#FFFFFF</item>

        <item name="colorError">#FF6B6B</item>
        <item name="colorOnError">#0A0D14</item>

        <item name="colorOutline">#2A3040</item>
        <item name="colorOutlineVariant">#1E2435</item>

        <!-- Системные окна -->
        <item name="android:colorBackground">#0A0D14</item>
        <item name="android:windowBackground">#0A0D14</item>
        <item name="android:statusBarColor">#0A0D14</item>
        <item name="android:navigationBarColor">#0F1219</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Тема для BottomSheetDialog -->
        <item name="bottomSheetDialogTheme">@style/Theme.FuelTracker.BottomSheet</item>

        <!-- Тема для MaterialToolbar -->
        <item name="toolbarStyle">@style/Widget.FuelTracker.Toolbar</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#1AF5A623</item>

    </style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- BOTTOM SHEET — cornerRadius 24dp, фон #12161F              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.FuelTracker.BottomSheet"
        parent="Theme.Material3.Dark.BottomSheetDialog">

        <item name="bottomSheetStyle">@style/Widget.FuelTracker.BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimAmount">0.6</item>

    </style>

    <style name="Widget.FuelTracker.BottomSheet"
        parent="Widget.Material3.BottomSheet">

        <!-- Фон bottom sheet с закруглёнными верхними углами -->
        <item name="backgroundTint">#12161F</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FuelTracker.BottomSheet</item>
        <item name="elevation">0dp</item>

    </style>

    <style name="ShapeAppearance.FuelTracker.BottomSheet"
        parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <!-- Только верхние углы закруглены на 24dp -->
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TOOLBAR                                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Widget.FuelTracker.Toolbar"
        parent="Widget.Material3.Toolbar">
        <item name="android:background">#0A0D14</item>
        <item name="titleTextColor">#FFFFFF</item>
        <item name="subtitleTextColor">#8892A4</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SPLASH THEME (без flash белого фона при старте)            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.FuelTracker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0D14</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_fuel_gauge_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.FuelTracker</item>
    </style>

</resources>